# Copy this file to `.env` (which is gitignored) and fill in real values, then
# load it into your shell before running pbmac:
#
#   set -a; source ./.env; set +a
#   ./pbmac ping && ./pbmac list
#
# pbmac reads these from the environment (flag > env > config). NEVER commit real
# credentials — only this .example template is tracked.

# Repository spec our client understands: [user@realm@]host[:port]:datastore
PBS_REPOSITORY=pbs.example.com:8007:my-datastore

# API token (create in the PBS UI; needs Datastore.Backup + Datastore.Read on the
# datastore). Format: USER@REALM!TOKENID:SECRET
PBS_API_TOKEN=user@pbs!mytoken:00000000-0000-0000-0000-000000000000

# Server certificate SHA-256 for TLS fingerprint pinning (colon-hex or bare hex).
# Get it with: openssl s_client -connect HOST:8007 </dev/null 2>/dev/null \
#              | openssl x509 -fingerprint -sha256 -noout
PBS_FINGERPRINT=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99

# Optional: passphrase for a scrypt/PBKDF2-protected keyfile (encrypted backups).
# PBS_ENCRYPTION_PASSWORD=
